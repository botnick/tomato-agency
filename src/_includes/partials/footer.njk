<footer class="footer" aria-labelledby="footerTitle">
  <h2 id="footerTitle" class="visually-hidden">ข้อมูลและการติดต่อ</h2>
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="brand" aria-label="Tomato Agency">
        <img src="/assets/img/wordmark.png" alt="Tomato Agency" class="brand__logo" width="160" height="40">
      </a>
      <p class="footer__tagline">
        เอเจนซี่ดูแลวีเจไลฟ์สด (Live VJ) ของไทย — fresh, sweet, &amp; ready to go live.
      </p>
      <ul class="social" role="list">
        <li>
          <a href="{{ site.line.short }}" target="_blank" rel="noopener" aria-label="LINE Official: {{ site.line.handle }}">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.628-.63.628H16.98a.631.631 0 0 1-.629-.628V9.23c0-.346.282-.629.633-.629h2.385c.346 0 .627.283.627.629 0 .349-.281.63-.63.63H17.61v1.125zm-3.855 3.016a.626.626 0 0 1-.631.627.6.6 0 0 1-.51-.252l-2.443-3.317v2.94a.629.629 0 0 1-1.259 0V9.23c0-.27.173-.51.428-.598.063-.024.13-.034.198-.034.197 0 .378.105.494.255l2.466 3.327V9.23c0-.346.281-.629.63-.629.346 0 .627.283.627.629zm-5.741 0a.629.629 0 0 1-.63.627.626.626 0 0 1-.628-.627V9.23c0-.346.282-.629.63-.629.345 0 .628.283.628.629zm-2.466.627H4.917a.625.625 0 0 1-.626-.627V9.23c0-.346.282-.629.63-.629.348 0 .63.283.63.629v3.016h1.752c.349 0 .63.283.63.63 0 .344-.281.628-.63.628M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
          </a>
        </li>
        <li>
          <a href="{{ site.ig.short }}" target="_blank" rel="noopener" aria-label="Instagram: {{ site.ig.handle }}">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07-3.2 0-3.58-.01-4.85-.07-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85C2.38 3.92 3.9 2.38 7.15 2.23 8.42 2.17 8.8 2.16 12 2.16zm0 5.68A4.16 4.16 0 1 0 12 16.16 4.16 4.16 0 0 0 12 7.84zm0 6.86a2.7 2.7 0 1 1 0-5.4 2.7 2.7 0 0 1 0 5.4zm4.32-7.94a.97.97 0 1 0 0 1.94.97.97 0 0 0 0-1.94z"/></svg>
          </a>
        </li>
      </ul>
    </div>

    <nav class="footer__nav" aria-label="ลิงค์ในเว็บ">
      {% for group in site.footerNav %}
      <div>
        <h3>{{ group.heading }}</h3>
        <ul role="list">
          {% for link in group.links %}
          <li><a href="{{ link.url }}">{{ link.label }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
      <div>
        <h3>ติดต่อ</h3>
        <ul role="list">
          <li><a href="{{ site.line.short }}" target="_blank" rel="noopener">LINE : {{ site.line.handle }}</a></li>
          <li><a href="{{ site.ig.short }}" target="_blank" rel="noopener">IG : {{ site.ig.handle }}</a></li>
          <li><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-row">
      <p>&copy; <span id="year">{{ site.founded }}</span> Tomato Agency. All rights reserved.</p>
      <p>
        <span class="display-serif" style="font-size:14px;letter-spacing:.3px;">tomato</span>
        <span class="display-sans" style="font-size:12px;letter-spacing:.5px;">agency</span>
        · Made in Bangkok
      </p>
    </div>
  </div>
</footer>
