<!-- ===== Latest articles ===== -->
{% set latest = collections.posts | limit(3) %}
{% if latest.length %}
<section class="latest" id="latest" aria-labelledby="latestTitle">
  <div class="container">
    <div class="section-head section-head--row">
      <h2 id="latestTitle" class="section-title">
        <span class="display-serif">from the</span>
        <span class="display-sans">journal</span>
      </h2>
      <a class="latest__all" href="/blog/">ดูบทความทั้งหมด →</a>
    </div>
    <div class="card-grid">
      {% for p in latest %}
      <a class="pcard" href="{{ p.url }}">
        {% if p.data.cover %}<div class="pcard__media"><img src="{{ p.data.cover }}" alt="" width="600" height="315" loading="lazy"></div>{% endif %}
        <div class="pcard__body">
          {% if p.data.category %}<span class="pcard__cat">{{ p.data.category }}</span>{% endif %}
          <h3 class="pcard__title">{{ p.data.title }}</h3>
          <p class="pcard__excerpt">{{ p.data.description }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- ===== FAQ ===== -->
<section class="faq" id="faq" aria-labelledby="faqTitle">
  <div class="container faq__inner">
    <div class="section-head">
      <h2 id="faqTitle" class="section-title">
        <span class="display-serif">frequently</span>
        <span class="display-sans">asked</span>
      </h2>
      <p class="section-lead">คำถามที่น้อง ๆ มักถามก่อนสมัคร — ถ้ายังสงสัยอะไร ทักไลน์ถามพี่ ๆ ได้เลย</p>
    </div>
    <div class="faq__list">
      <details class="faq__item"><summary><span>อายุเท่าไหร่ถึงจะสมัครออดิชั่นได้?</span><span class="faq__plus" aria-hidden="true"></span></summary><div class="faq__answer">ผู้สมัครต้องมีอายุ <strong>18 ปีบริบูรณ์ขึ้นไป</strong> ไม่จำกัดอายุสูงสุด ขอแค่มีใจรักและพร้อมพัฒนาตัวเอง เราเปิดกว้างสำหรับทุกคน</div></details>
      <details class="faq__item"><summary><span>ต้องมีประสบการณ์ในวงการไหม?</span><span class="faq__plus" aria-hidden="true"></span></summary><div class="faq__answer">ไม่จำเป็น พี่ ๆ ทีมงานจะดูแลและสอนตั้งแต่ขั้นพื้นฐาน ไม่ว่าจะตั้งค่ายไลฟ์ พูดหน้ากล้อง หรือเทคนิคเล็ก ๆ น้อย ๆ ระหว่างไลฟ์</div></details>
      <details class="faq__item"><summary><span>การสมัครมีค่าใช้จ่ายหรือไม่?</span><span class="faq__plus" aria-hidden="true"></span></summary><div class="faq__answer"><strong>ฟรี 100%</strong> ไม่มีค่าใช้จ่ายในการสมัครหรือเทรนนิ่งใด ๆ ทั้งสิ้น เราคัดเลือกและดูแล Live VJ ด้วยความเชื่อมั่นในศักยภาพ</div></details>
      <details class="faq__item"><summary><span>ทราบผลภายในกี่วัน?</span><span class="faq__plus" aria-hidden="true"></span></summary><div class="faq__answer">ทีมงานจะตรวจสอบและแจ้งผลผ่าน <strong>LINE</strong> ภายใน 1-3 วันทำการ (ไม่รวมเสาร์-อาทิตย์และวันหยุดนักขัตฤกษ์)</div></details>
      <details class="faq__item"><summary><span>ใช้รูป AI หรือฟิลเตอร์สมัครได้ไหม?</span><span class="faq__plus" aria-hidden="true"></span></summary><div class="faq__answer">ไม่ได้ ต้องใช้รูปและคลิปวิดีโอ<strong>จริงเท่านั้น</strong> ไม่ใช้ฟิลเตอร์และ AI สร้างภาพ เพื่อให้ทีมงานเห็นตัวตนจริงของคุณ</div></details>
      <details class="faq__item"><summary><span>สมัครแล้วต้องไลฟ์บ่อยแค่ไหน?</span><span class="faq__plus" aria-hidden="true"></span></summary><div class="faq__answer">เริ่มต้นที่ <strong>10 ชั่วโมง/เดือน</strong>ตามเงื่อนไขและนโยบายของแพลตฟอร์มเลย — น้องเลือกเวลาเองได้ทั้งกลางวันกลางคืน พี่ ๆ จะช่วยวางตารางให้<strong>เข้ากับไลฟ์สไตล์ของน้อง</strong> เน้นสม่ำเสมอแบบสบาย ๆ ไม่กดดัน ค่อย ๆ ขยับขึ้นไปพร้อมแฟน ๆ ที่ตามดูประจำ</div></details>
    </div>
    <p class="faq__more">ยังมีคำถามอีก? <a href="/faq/">ดูคำถามที่พบบ่อยทั้งหมด</a></p>
  </div>
</section>

